     # A function that captures outer defs AND has a var+assign (mutable local).
     # Before the fix, the mutable local generated StoreUpvalue with a u8 index
     # that wrapped around, corrupting the wrong slot.
     (defn test-fn [x &named flag]
       (def @result nil)
       (when flag (assign result (+ d0 d255 d259 x)))
       result)

     # A function that reads high-indexed captures to verify LoadUpvalue works.
     (defn read-high []
       (+ d255 d256 d257 d258 d259))
     {:test-fn test-fn :read-high read-high})))

